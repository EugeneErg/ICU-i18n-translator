{
  "name": "eugene-erg/icu-i18n-translator",
  "description": "Text translation using multiple neural network APIs",
  "type": "library",
  "license": "MIT",
  "autoload": {
    "psr-4": {
      "EugeneErg\\IcuI18nTranslator\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "require": {
    "php": "^8.2",
    "ext-intl": "*",
    "eugene-erg/icu-message-format-parser": "^1.0"
  },
  "minimum-stability": "stable",
  "require-dev": {
    "guzzlehttp/guzzle": "^7.9",
    "phpstan/phpstan": "^2.2",
    "friendsofphp/php-cs-fixer": "^3.95",
    "phpunit/phpunit": "^12.5"
  }
}
